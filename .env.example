# Nom de projet Compose
COMPOSE_PROJECT_NAME=aimoodle
# Hote servi par le proxy Caddy (SNI + certificat interne). Doit correspondre a
# MOODLE_WWWROOT. En prod : le FQDN de l'etablissement (ex. lms.etablissement.cm).
PROXY_HOST=localhost
# URL publique Moodle (HTTPS via le proxy). Doit correspondre a PROXY_HOST.
MOODLE_WWWROOT=https://localhost
